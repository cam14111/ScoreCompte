# Google OAuth Configuration for Google Drive Backup
# Follow the setup guide in BACKUP_SETUP.md to configure these values

# Google OAuth 2.0 Client ID (required for Google Drive backup)
# Obtain from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# OAuth Redirect URI (optional, defaults to window.location.origin)
# Usually matches your deployment URL (e.g., http://localhost:5173 for dev)
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173
